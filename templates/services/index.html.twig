{% extends "base.html.twig" %}

{% block title %}Services — NorthOps{% endblock %}
{% block description %}Four focused service lines: web application engineering, content and data pipelines, DevOps and CI/CD, and AI engineering. Fixed-price MVPs starting at CAD $3,600.{% endblock %}

{% block content %}
    <!-- Page Intro -->
    <section class="section section-hero">
        <div class="container">
            <h1>Services</h1>
            <p class="hero-sub">
                Four focused service lines, each scoped as a fixed-price MVP. We build what we know
                exceptionally well — and nothing else.
            </p>
        </div>
    </section>

    <!-- Service Grid -->
    <section class="section">
        <div class="container">
            <div class="service-grid">
                <a href="/services/web-application-engineering" class="service-card">
                    <h3>Web Application Engineering</h3>
                    <p>Full-stack Laravel and Vue applications scoped, built, and shipped as a working product. Includes auth, admin, deployment, and documentation.</p>
                    <span class="service-price">Starting at CAD $6,000</span>
                </a>
                <a href="/services/content-data-pipelines" class="service-card">
                    <h3>Content &amp; Data Pipelines</h3>
                    <p>Automated ingestion, transformation, and delivery pipelines that move data where it needs to go — reliably and on schedule.</p>
                    <span class="service-price">Starting at CAD $4,800</span>
                </a>
                <a href="/services/devops-cicd" class="service-card">
                    <h3>DevOps &amp; CI/CD</h3>
                    <p>Production-ready infrastructure, deployment pipelines, and monitoring configured for your stack and your team's workflow.</p>
                    <span class="service-price">Starting at CAD $3,600</span>
                </a>
                <a href="/services/ai-engineering" class="service-card">
                    <h3>AI Engineering</h3>
                    <p>LLM integrations, RAG pipelines, and AI-powered features built into your product — not bolted on as an afterthought.</p>
                    <span class="service-price">Starting at CAD $7,800</span>
                </a>
            </div>
        </div>
    </section>

    <!-- CTA Banner -->
    <section class="section section-cta">
        <div class="container">
            <h2>Have a project in mind?</h2>
            <a href="/contact" class="btn btn-primary btn-lg">Get Started</a>
        </div>
    </section>
{% endblock %}

{% extends "base.html.twig" %}

{% block title %}AI Engineering — NorthOps{% endblock %}
{% block description %}LLM integrations, RAG pipelines, and AI-powered features built into your product. Fixed-price MVPs starting at CAD $7,800.{% endblock %}

{% block content %}
    <!-- Hero -->
    <section class="section section-hero">
        <div class="container">
            <h1>AI Engineering</h1>
            <p class="hero-sub">
                LLM integrations, RAG pipelines, and AI-powered features built into your
                product — not bolted on as an afterthought.
            </p>
        </div>
    </section>

    <!-- Deliverables -->
    <section class="section">
        <div class="container container-narrow">
            <h2>Deliverables</h2>
            <ul class="bullet-list">
                <li>LLM integration with prompt engineering, context management, and response handling</li>
                <li>RAG pipeline with document ingestion, embedding, vector search, and retrieval</li>
                <li>AI-powered feature (classification, summarization, extraction, or generation) integrated into your application</li>
                <li>Evaluation framework with test cases, accuracy metrics, and cost tracking</li>
                <li>Technical documentation covering architecture, prompt design, and operational considerations</li>
            </ul>
        </div>
    </section>

    <!-- MVP Block -->
    <section class="section section-alt">
        <div class="container container-narrow">
            <h2>MVP scope</h2>
            <div class="mvp-block">
                <div class="mvp-detail">
                    <span class="mvp-label">Delivery</span>
                    <span class="mvp-value">5 business days</span>
                </div>
                <div class="mvp-detail">
                    <span class="mvp-label">Price</span>
                    <span class="mvp-value">CAD $7,800–$9,360</span>
                </div>
                <div class="mvp-detail">
                    <span class="mvp-label">Payment</span>
                    <span class="mvp-value">50% upfront, 50% on delivery</span>
                </div>
            </div>
            <p class="mvp-assumptions">
                Assumes a single AI feature integrated into an existing application with one
                LLM provider and a standard RAG pipeline. Fine-tuning, multi-model orchestration,
                or agent frameworks are scoped separately.
            </p>
        </div>
    </section>

    <!-- Stack -->
    <section class="section">
        <div class="container container-narrow">
            <h2>Stack</h2>
            <div class="tag-list">
                <span class="tag">OpenAI</span>
                <span class="tag">Anthropic</span>
                <span class="tag">LangChain</span>
                <span class="tag">PostgreSQL + pgvector</span>
                <span class="tag">Python</span>
                <span class="tag">TypeScript</span>
            </div>
        </div>
    </section>

    <!-- Ideal Client -->
    <section class="section section-alt">
        <div class="container container-narrow">
            <h2>Ideal client</h2>
            <p class="text-block">
                You want to add AI capabilities to your product — search that understands intent,
                content that writes itself, data that classifies automatically — but you need an
                engineer who understands both the AI and the application it's being integrated into.
                Not a data scientist with a notebook, but an engineer who ships production features.
            </p>
        </div>
    </section>

    <!-- CTA Banner -->
    <section class="section section-cta">
        <div class="container">
            <h2>Ready to add AI to your product?</h2>
            <a href="/contact" class="btn btn-primary btn-lg">Get Started</a>
        </div>
    </section>
{% endblock %}

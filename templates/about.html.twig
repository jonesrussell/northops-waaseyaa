{% extends "base.html.twig" %}

{% block title %}About — NorthOps{% endblock %}
{% block description %}NorthOps is a boutique AI systems and platform engineering practice in Northern Ontario, led by an Anishinaabe operator from Sagamok First Nation.{% endblock %}

{% block content %}
    <!-- About Text -->
    <section class="section section-hero">
        <div class="container container-narrow">
            <h1>About NorthOps</h1>
        </div>
    </section>

    <section class="section">
        <div class="container container-narrow">
            <div class="text-block">
                <p>
                    NorthOps is a boutique AI systems architecture and platform engineering practice.
                    We design and build production systems for scaleups and public-sector teams
                    adopting AI in earnest — not in prototypes.
                </p>
                <p>
                    We started NorthOps because the gap between "demo-quality AI" and
                    "AI that works in production" is wider than most teams expect, and
                    the people who can close it are scarce. Our work centers on spec-driven
                    development, multi-agent orchestration, and the deterministic patterns that
                    keep AI-native systems working six months after they ship.
                </p>
                <p>
                    We work from Northern Ontario — Sudbury and Noelville — remote-first with
                    clients across Canada and the public sector. The firm is Indigenous-led:
                    Russell is Anishinaabe, rooted in Sagamok First Nation, which shapes how we
                    approach data sovereignty, community stewardship, and Indigenous procurement.
                </p>
            </div>
        </div>
    </section>

    <!-- Team Bios -->
    <section class="section section-alt">
        <div class="container container-narrow">
            <h2>The team</h2>
            <div class="team-grid">
                <div class="team-member">
                    <img src="/images/team/russell-jones.jpg" alt="Russell Jones" class="team-photo">
                    <h3>Russell Jones</h3>
                    <p class="team-title">Principal Engineer &amp; Founder</p>
                    <p>
                        Russell leads NorthOps. He focuses on AI systems architecture,
                        spec-driven development, and the Waaseyaa framework — an entity-first,
                        AI-native PHP platform that powers production deployments including
                        OIATC. His practice is organized around codified context, agent-safe
                        repos, and the patterns that let AI-assisted development scale without
                        breaking the codebase.
                    </p>
                    <p>
                        Before NorthOps, Russell spent over a decade building web systems across
                        agencies, startups, and enterprise clients — content platforms,
                        e-commerce, and data pipelines that run in production today.
                    </p>
                    <p>
                        Russell is Anishinaabe, rooted in Sagamok First Nation. That context
                        informs the Indigenous Data Sovereignty service line and shapes how the
                        firm approaches OCAP® principles, community stewardship, and Indigenous
                        procurement. Based in Sudbury, Ontario.
                        Public work: <a href="https://jonesrussell.github.io" target="_blank" rel="noopener">jonesrussell.github.io</a>.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Collaborators -->
    <section class="section">
        <div class="container container-narrow">
            <h2>Collaborators</h2>
            <div class="team-grid">
                <div class="team-member">
                    <img src="/images/team/luc-hebert.jpg" alt="Luc Hebert" class="team-photo">
                    <h3>Luc Hebert</h3>
                    <p class="team-title">Frontend &amp; TypeScript Collaborator</p>
                    <p>
                        Luc collaborates on NorthOps engagements where frontend architecture,
                        TypeScript, and LLM-powered interface work intersect. He brings senior
                        full-stack experience across embedded systems, LMS platforms, insurance
                        tech, and e-commerce at Shopify scale. Based in Noelville, Ontario.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Principles -->
    <section class="section section-alt">
        <div class="container container-narrow">
            <h2>Principles</h2>
            <ul class="bullet-list">
                <li>Senior engineering judgment on every engagement — no juniors, no exceptions.</li>
                <li>Spec-driven development — the spec is the artifact; the code is an implementation detail.</li>
                <li>Deterministic over impressive — production systems are measured in months of uptime, not demo quality.</li>
                <li>Direct communication — you talk to the engineers writing the code.</li>
                <li>Clean handoffs — documented, deployed, and ready for your team to extend.</li>
                <li>Honest about fit — if we're not the right firm for your project, we'll say so.</li>
                <li>Data sovereignty by default — community ownership and consent are design inputs, not afterthoughts.</li>
            </ul>
        </div>
    </section>

    <!-- Trust -->
    <section class="section">
        <div class="container container-narrow">
            <h2>Firm details</h2>
            <ul class="bullet-list">
                <li>HST-registered Ontario sole proprietorship.</li>
                <li>Northern Ontario, Canada — remote-first.</li>
                <li>Indigenous-led — Anishinaabe, Sagamok First Nation.</li>
                <li>Framework: <a href="https://github.com/waaseyaa" target="_blank" rel="noopener">github.com/waaseyaa</a>.</li>
                <li>Principal's public work: <a href="https://jonesrussell.github.io" target="_blank" rel="noopener">jonesrussell.github.io</a>.</li>
                <li>Contact: <a href="mailto:contact@northops.ca">contact@northops.ca</a>.</li>
            </ul>
        </div>
    </section>

    <!-- CTA Banner -->
    <section class="section section-cta">
        <div class="container">
            <h2>Work with us.</h2>
            <a href="/contact" class="btn btn-primary btn-lg">Book a discovery call</a>
        </div>
    </section>
{% endblock %}

{% extends "base.html.twig" %}

{% block title %}Advisory &amp; Fractional Leadership — NorthOps{% endblock %}
{% block description %}Senior engineering judgment on retainer. Architecture decisions, roadmap reviews, and hiring calls, embedded in your team one or two days a week.{% endblock %}

{% block content %}
    <!-- Hero -->
    <section class="section section-hero">
        <div class="container">
            <h1>Advisory &amp; Fractional Leadership</h1>
            <p class="hero-sub">
                Senior judgment on retainer. One or two days a week, embedded in your
                architecture decisions, roadmap reviews, and hiring calls. Alternative to a
                full-time senior hire when scope doesn't justify the headcount.
            </p>
        </div>
    </section>

    <!-- Deliverables -->
    <section class="section">
        <div class="container container-narrow">
            <h2>What this looks like</h2>
            <ul class="bullet-list">
                <li>Weekly embedded time inside your team — architecture decisions, design reviews, and roadmap work</li>
                <li>PR reviews and code walkthroughs with your engineers, with a focus on mentorship and pattern transfer</li>
                <li>Hiring support — rubric design, senior-level interviews, and take-home review</li>
                <li>Technical due diligence on vendor and partnership decisions</li>
                <li>Escalation channel for production incidents that need a senior second opinion</li>
            </ul>
        </div>
    </section>

    <!-- Engagement shapes -->
    <section class="section section-alt">
        <div class="container container-narrow">
            <h2>How we engage</h2>
            <p class="text-block">
                This runs as a <strong>Fractional Retainer</strong> from CAD $8,000/month
                (one day per week) or as pre-booked <strong>Advisory Hours</strong> from CAD
                $250/hour when you need a senior second opinion without the ongoing commitment.
            </p>
            <p class="text-block">
                <a href="/services#engagement-shapes">See engagement shapes →</a>
            </p>
        </div>
    </section>

    <!-- Ideal Client -->
    <section class="section">
        <div class="container container-narrow">
            <h2>Ideal client</h2>
            <p class="text-block">
                You're a founder, CTO, or engineering manager who needs senior input — on
                architecture, hiring, or technical strategy — but doesn't need (or can't justify)
                a full-time senior engineer on payroll. Or you have a senior team and want a
                trusted outside perspective on decisions that matter.
            </p>
        </div>
    </section>

    <!-- CTA Banner -->
    <section class="section section-cta">
        <div class="container">
            <h2>Need senior judgment on retainer?</h2>
            <a href="/contact" class="btn btn-primary btn-lg">Book a discovery call</a>
        </div>
    </section>
{% endblock %}

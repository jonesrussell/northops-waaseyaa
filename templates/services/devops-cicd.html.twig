{% extends "base.html.twig" %}

{% block title %}DevOps &amp; CI/CD — NorthOps{% endblock %}
{% block description %}Production-ready infrastructure, deployment pipelines, and monitoring. Fixed-price MVPs starting at CAD $3,600.{% endblock %}

{% block content %}
    <!-- Hero -->
    <section class="section section-hero">
        <div class="container">
            <h1>DevOps &amp; CI/CD</h1>
            <p class="hero-sub">
                Production-ready infrastructure, deployment pipelines, and monitoring configured
                for your stack and your team's workflow.
            </p>
        </div>
    </section>

    <!-- Deliverables -->
    <section class="section">
        <div class="container container-narrow">
            <h2>Deliverables</h2>
            <ul class="bullet-list">
                <li>CI/CD pipeline with automated testing, linting, and deployment</li>
                <li>Server provisioning and configuration (Caddy, PHP-FPM, Node, or Docker)</li>
                <li>Zero-downtime deployment with rollback capability</li>
                <li>Monitoring and alerting for application health and uptime</li>
                <li>Infrastructure documentation and operational runbooks</li>
            </ul>
        </div>
    </section>

    <!-- MVP Block -->
    <section class="section section-alt">
        <div class="container container-narrow">
            <h2>MVP scope</h2>
            <div class="mvp-block">
                <div class="mvp-detail">
                    <span class="mvp-label">Delivery</span>
                    <span class="mvp-value">3 business days</span>
                </div>
                <div class="mvp-detail">
                    <span class="mvp-label">Price</span>
                    <span class="mvp-value">CAD $3,600–$4,320</span>
                </div>
                <div class="mvp-detail">
                    <span class="mvp-label">Payment</span>
                    <span class="mvp-value">50% upfront, 50% on delivery</span>
                </div>
            </div>
            <p class="mvp-assumptions">
                Assumes a single application deployed to one production environment with a
                standard CI/CD pipeline. Multi-environment setups, container orchestration,
                or infrastructure-as-code for complex topologies is scoped separately.
            </p>
        </div>
    </section>

    <!-- Stack -->
    <section class="section">
        <div class="container container-narrow">
            <h2>Stack</h2>
            <div class="tag-list">
                <span class="tag">GitHub Actions</span>
                <span class="tag">Deployer</span>
                <span class="tag">Docker</span>
                <span class="tag">Caddy</span>
                <span class="tag">Nginx</span>
                <span class="tag">Linux</span>
                <span class="tag">Bash</span>
                <span class="tag">systemd</span>
            </div>
        </div>
    </section>

    <!-- Ideal Client -->
    <section class="section section-alt">
        <div class="container container-narrow">
            <h2>Ideal client</h2>
            <p class="text-block">
                You have a working application that deploys manually (or not at all) and you
                need a real pipeline — automated tests, zero-downtime deploys, monitoring, and
                a setup your team can maintain without calling you every time something breaks.
            </p>
        </div>
    </section>

    <!-- CTA Banner -->
    <section class="section section-cta">
        <div class="container">
            <h2>Ready to automate your deployments?</h2>
            <a href="/contact" class="btn btn-primary btn-lg">Get Started</a>
        </div>
    </section>
{% endblock %}

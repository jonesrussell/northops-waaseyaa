{% extends "base.html.twig" %}

{% block title %}NorthOps — Senior Engineering. Shipped in Days.{% endblock %}
{% block description %}Two senior engineers delivering fixed-price MVPs starting at CAD $3,600. Web apps, pipelines, DevOps, and AI engineering from Northern Ontario.{% endblock %}

{% block content %}
    <!-- Hero -->
    <section class="section section-hero">
        <div class="container">
            <h1>Senior engineering.<br>Shipped in days.</h1>
            <p class="hero-sub">
                NorthOps is two senior engineers who scope, build, and deliver fixed-price MVPs
                starting at CAD&nbsp;$3,600. No juniors, no overhead, no surprises.
            </p>
            <a href="/contact" class="btn btn-primary btn-lg">Get Started</a>
        </div>
    </section>

    <!-- Service Grid -->
    <section class="section">
        <div class="container">
            <div class="service-grid">
                <a href="/services/web-application-engineering" class="service-card">
                    <h3>Web Application Engineering</h3>
                    <p>Full-stack Laravel and Vue applications scoped, built, and shipped as a working product. Includes auth, admin, deployment, and documentation.</p>
                </a>
                <a href="/services/content-data-pipelines" class="service-card">
                    <h3>Content &amp; Data Pipelines</h3>
                    <p>Automated ingestion, transformation, and delivery pipelines that move data where it needs to go — reliably and on schedule.</p>
                </a>
                <a href="/services/devops-cicd" class="service-card">
                    <h3>DevOps &amp; CI/CD</h3>
                    <p>Production-ready infrastructure, deployment pipelines, and monitoring configured for your stack and your team's workflow.</p>
                </a>
                <a href="/services/ai-engineering" class="service-card">
                    <h3>AI Engineering</h3>
                    <p>LLM integrations, RAG pipelines, and AI-powered features built into your product — not bolted on as an afterthought.</p>
                </a>
            </div>
        </div>
    </section>

    <!-- Why NorthOps / Proof Points -->
    <section class="section section-alt">
        <div class="container">
            <h2>Why NorthOps</h2>
            <div class="proof-grid">
                <div class="proof-point">
                    <h3>Senior-only every time</h3>
                    <p>Every project is built by senior engineers with 10+ years of experience. No handoffs to juniors, no bait-and-switch.</p>
                </div>
                <div class="proof-point">
                    <h3>Full-stack coverage</h3>
                    <p>Backend, frontend, infrastructure, and AI — covered by two engineers who work across the entire stack daily.</p>
                </div>
                <div class="proof-point">
                    <h3>Days not weeks</h3>
                    <p>Fixed-scope MVPs delivered in 3–5 business days. We move fast because we've built these systems many times before.</p>
                </div>
                <div class="proof-point">
                    <h3>No overhead tax</h3>
                    <p>No project managers, no account executives, no layers between you and the people writing the code. You talk directly to the engineers.</p>
                </div>
                <div class="proof-point">
                    <h3>AI capability built in</h3>
                    <p>Every engagement has access to modern AI tooling — from code generation to LLM integrations — because it's part of how we work.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Process Steps -->
    <section class="section">
        <div class="container">
            <h2>How it works</h2>
            <div class="process-steps">
                <div class="process-step">
                    <span class="step-number">1</span>
                    <h3>Discovery call</h3>
                    <p>A free 15–30 minute conversation to understand your project, timeline, and goals. No commitment, no pitch.</p>
                </div>
                <div class="process-step">
                    <span class="step-number">2</span>
                    <h3>Scope</h3>
                    <p>We define exactly what gets built, what's included, and what's out of scope. You'll know the deliverables and price before anything starts.</p>
                </div>
                <div class="process-step">
                    <span class="step-number">3</span>
                    <h3>SOW + payment</h3>
                    <p>A clear statement of work with fixed pricing. 50% upfront, 50% on delivery. No hourly billing, no scope creep surprises.</p>
                </div>
                <div class="process-step">
                    <span class="step-number">4</span>
                    <h3>Build</h3>
                    <p>We build in short, focused sprints with daily progress updates. You'll see working software early and often.</p>
                </div>
                <div class="process-step">
                    <span class="step-number">5</span>
                    <h3>Deliver</h3>
                    <p>Deployed, documented, and handed off. You get the source code, deployment guide, and a working system — not a pile of files.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Team -->
    <section class="section section-alt">
        <div class="container">
            <h2>The team</h2>
            <div class="team-grid">
                <div class="team-member">
                    <img src="https://avatars.githubusercontent.com/u/499552?v=4" alt="Russell Jones" class="team-photo">
                    <h3>Russell Jones</h3>
                    <p class="team-title">Senior Engineer &amp; Co-Founder</p>
                    <p>Backend systems, data pipelines, and deployment infrastructure. Russell builds the services that run in production — queue workers, crawlers, API integrations, and the CI/CD that ships them reliably.</p>
                </div>
                <div class="team-member">
                    <img src="/images/team/luc-hebert.jpg" alt="Luc Hebert" class="team-photo">
                    <h3>Luc Hebert</h3>
                    <p class="team-title">Senior Engineer &amp; Co-Founder</p>
                    <p>Frontend architecture, TypeScript, and AI integrations. Luc builds the interfaces and intelligent features that users interact with — from component systems to LLM-powered workflows.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Banner -->
    <section class="section section-cta">
        <div class="container">
            <h2>Ready to start?</h2>
            <p>Book a free discovery call.</p>
            <a href="/contact" class="btn btn-primary btn-lg">Book a Discovery Call</a>
        </div>
    </section>
{% endblock %}

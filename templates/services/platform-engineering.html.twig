{% extends "base.html.twig" %}

{% block title %}Platform Engineering — NorthOps{% endblock %}
{% block description %}Production systems on Laravel, Symfony, or modern TypeScript stacks. Entity-first architecture, split-package design, observability, CI/CD, agent-safe repos.{% endblock %}

{% block content %}
    <!-- Hero -->
    <section class="section section-hero">
        <div class="container">
            <h1>Platform Engineering</h1>
            <p class="hero-sub">
                Production systems on Laravel, Symfony, or modern TypeScript stacks.
                Entity-first architecture, split-package design, observability, CI/CD,
                agent-safe repos. We ship code that your team can extend without us.
            </p>
        </div>
    </section>

    <!-- Deliverables -->
    <section class="section">
        <div class="container container-narrow">
            <h2>Deliverables</h2>
            <ul class="bullet-list">
                <li>Application or service built on Laravel, Symfony, or TypeScript with entity-first architecture</li>
                <li>CI/CD pipeline configured for your stack, with deployment, testing, and rollback</li>
                <li>Observability layer: structured logging, metrics, and alerting</li>
                <li>Agent-safe repo conventions — CLAUDE.md, codified context, and SKILL.md files where relevant</li>
                <li>Technical documentation covering architecture, deployment, and operational handoff</li>
            </ul>
        </div>
    </section>

    <!-- Engagement shapes -->
    <section class="section section-alt">
        <div class="container container-narrow">
            <h2>How we engage</h2>
            <p class="text-block">
                Platform engineering usually runs as a <strong>Fixed-Price MVP</strong> (from
                CAD $8,000, 1–2 week delivery) for scoped builds, or an
                <strong>Implementation Contract</strong> (from CAD $1,500/day) when the work
                unfolds across a longer horizon. Speed is a consequence of patterns we've
                shipped before — not a universal claim.
            </p>
            <p class="text-block">
                <a href="/services#engagement-shapes">See engagement shapes →</a>
            </p>
        </div>
    </section>

    <!-- Stack -->
    <section class="section">
        <div class="container container-narrow">
            <h2>Stack</h2>
            <div class="tag-list">
                <span class="tag">Laravel</span>
                <span class="tag">Symfony</span>
                <span class="tag">TypeScript</span>
                <span class="tag">Go</span>
                <span class="tag">PostgreSQL</span>
                <span class="tag">GitHub Actions</span>
                <span class="tag">Docker</span>
                <span class="tag">Deployer</span>
            </div>
        </div>
    </section>

    <!-- Ideal Client -->
    <section class="section section-alt">
        <div class="container container-narrow">
            <h2>Ideal client</h2>
            <p class="text-block">
                You need a production system built well the first time — one your engineers can
                extend, deploy, and understand six months from now. You want senior judgment on
                architecture decisions, not a freelancer who leaves you a pile of files.
            </p>
        </div>
    </section>

    <!-- CTA Banner -->
    <section class="section section-cta">
        <div class="container">
            <h2>Need a production system that lasts?</h2>
            <a href="/contact" class="btn btn-primary btn-lg">Book a discovery call</a>
        </div>
    </section>
{% endblock %}

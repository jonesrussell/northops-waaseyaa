{% extends "base.html.twig" %}

{% block title %}Sign In — NorthOps{% endblock %}

{% block content %}
<section class="auth-page">
    <div class="auth-card">
        <h1>Sign In</h1>
        <p class="auth-subtitle">Access the NorthOps dashboard</p>

        <form method="POST" action="/login">
            {% if redirect is defined and redirect %}
                <input type="hidden" name="redirect" value="{{ redirect }}">
            {% endif %}

            <div class="form-group{% if errors.email is defined %} has-error{% endif %}">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="{{ values.email ?? '' }}" autocomplete="email" autofocus required>
                {% if errors.email is defined %}
                    <span class="form-error">{{ errors.email }}</span>
                {% endif %}
            </div>

            <div class="form-group{% if errors.password is defined %} has-error{% endif %}">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" autocomplete="current-password" required>
                {% if errors.password is defined %}
                    <span class="form-error">{{ errors.password }}</span>
                {% endif %}
            </div>

            <button type="submit" class="btn btn-primary btn-full">Sign In</button>
        </form>
    </div>
</section>
{% endblock %}
